# Copy this file to .env.local and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Hotel timezone — used when building timestamps for check-in/check-out.
# Must be a valid IANA timezone string.
NEXT_PUBLIC_HOTEL_TIMEZONE=Europe/Berlin

# Secret token for the automatic iCal sync cron job.
# Must match the CRON_SECRET set in Vercel (or your cron service).
# Generate a random string: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
